<Window x:Class="GestionComerce.Main.Inventory.WArticleDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Détails de l'Article"
        Width="1200" Height="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Modern Color Palette -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#06B6D4"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="BackgroundLight" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SurfaceWhite" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderLight" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#8B5CF6"/>

        <!-- Shadows -->
        <DropShadowEffect x:Key="ShadowXl" BlurRadius="48" ShadowDepth="0" Color="#000000" Opacity="0.15"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="0" Color="#000000" Opacity="0.08"/>

        <!-- Header Title -->
        <Style x:Key="HeaderTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- Section Title -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>

        </Style>

        <!-- Value Style -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Info Card Style -->
        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceWhite}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- Stat Card Style -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#667EEA" Offset="0"/>
                        <GradientStop Color="#764BA2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- Badge Style -->
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,24"/>
        </Style>

        <!-- Close Button -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="32,14"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="0" Margin="24"
            Background="{StaticResource BackgroundLight}" 
            CornerRadius="24"
            Effect="{StaticResource ShadowXl}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="{StaticResource SurfaceWhite}"
                    CornerRadius="24,24,0,0"
                    BorderBrush="{StaticResource BorderLight}"
                    BorderThickness="0,0,0,1"
                    Padding="40,32">
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📦" FontSize="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="HeaderArticleName"
                                       Text="Détails de l'Article"
                                       Style="{StaticResource HeaderTitleStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="HeaderSubtitle"
                                   Text="Informations complètes sur le produit"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <Button Name="CloseButton"
                            Style="{StaticResource CloseButtonStyle}"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Padding="40,32">
                <StackPanel>
                    <!-- Image and Key Stats Row -->
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Article Image Card -->
                        <Border Grid.Column="0"
                                Style="{StaticResource InfoCardStyle}"
                                Margin="0">
                            <StackPanel>
                                <TextBlock Text="Image du Produit" 
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,16"/>
                                <Border Background="#F8FAFC"
                                        BorderBrush="{StaticResource BorderLight}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Height="250">
                                    <Image x:Name="ArticleImageDisplay"
                                           Stretch="Uniform"
                                           Margin="8"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Key Stats Cards -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Stock Card -->
                            <Border Grid.Row="0" Style="{StaticResource StatCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="📊 Stock Disponible" 
                                               Foreground="White" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Opacity="0.9"
                                               Margin="0,0,0,8"/>
                                    <TextBlock x:Name="StockQuantite"
                                               Text="0"
                                               Foreground="White"
                                               FontSize="36"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="StockStatus"
                                               Text="En stock"
                                               Foreground="White"
                                               FontSize="13"
                                               Opacity="0.8"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Price Card -->
                            <Border Grid.Row="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#11998E" Offset="0"/>
                                        <GradientStop Color="#38EF7D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="💰 Prix de Vente" 
                                               Foreground="White" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Opacity="0.9"
                                               Margin="0,0,0,8"/>
                                    <TextBlock x:Name="DisplayPrixVente"
                                               Text="0.00 DH"
                                               Foreground="White"
                                               FontSize="32"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="ProfitMargin"
                                               Text="Marge: 0%"
                                               Foreground="White"
                                               FontSize="13"
                                               Opacity="0.8"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Value Card -->
                            <Border Grid.Row="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F2994A" Offset="0"/>
                                        <GradientStop Color="#F2C94C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatCardStyle}">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock Text="💎 Valeur en Stock" 
                                               Foreground="White" 
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Opacity="0.9"
                                               Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TotalValue"
                                               Text="0.00 DH"
                                               Foreground="White"
                                               FontSize="28"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="ValueSubtext"
                                               Text="Prix de vente total"
                                               Foreground="White"
                                               FontSize="13"
                                               Opacity="0.8"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Essential Information -->
                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="📋 Informations Essentielles" 
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="ID Article" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="ArticleID" Style="{StaticResource ValueStyle}"/>

                                    <TextBlock Text="Fournisseur" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="Fournisseur" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Code Article" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="Code" Style="{StaticResource ValueStyle}" FontFamily="Consolas"/>

                                    <TextBlock Text="Famille" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="Famille" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="SKU" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="SKU" Style="{StaticResource ValueStyle}" FontFamily="Consolas"/>

                                    <TextBlock Text="Marque" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="Marque" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="Fabricant" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="Manufacturer" Style="{StaticResource ValueStyle}"/>

                                    <TextBlock Text="Pays d'Origine" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="CountryOfOrigin" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Description" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="Description" 
                                       Style="{StaticResource ValueStyle}"
                                       Margin="0,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Pricing Information -->
                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="💰 Informations de Prix" 
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Prix d'Achat" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="PrixAchat" 
                                               Style="{StaticResource ValueStyle}"
                                               Foreground="{StaticResource SuccessGreen}"
                                               FontWeight="SemiBold"
                                               FontSize="18"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Prix de Vente" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="PrixVente" 
                                               Style="{StaticResource ValueStyle}"
                                               Foreground="{StaticResource DangerRed}"
                                               FontWeight="SemiBold"
                                               FontSize="18"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Prix MP" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="PrixMP" 
                                               Style="{StaticResource ValueStyle}"
                                               Foreground="{StaticResource AccentPurple}"
                                               FontWeight="SemiBold"
                                               FontSize="18"/>
                                </StackPanel>

                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="TVA" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TVA" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Prix de Gros" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="PrixGros" 
                                               Style="{StaticResource ValueStyle}"
                                               Foreground="{StaticResource AccentCyan}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Qté Min pour Gros" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="MinQuantityForGros" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Stock Management -->
                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="📊 Gestion de Stock" 
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Quantité Actuelle" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="Quantite" 
                                               Style="{StaticResource ValueStyle}"
                                               FontWeight="Bold"
                                               FontSize="20"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Stock Minimum" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="MinimumStock" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Stock Maximum" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="MaximumStock" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="Unité de Mesure" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="UnitOfMeasure" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Emplacement" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="StorageLocation" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Dernier Réappro." Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="LastRestockDate" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Stock Badges -->
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="UnlimitedStockBadge" 
                                        Style="{StaticResource BadgeStyle}"
                                        Background="#DBEAFE"
                                        Visibility="Collapsed"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="♾️ Stock Illimité" 
                                               Foreground="#1E40AF"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <Border x:Name="PerishableBadge" 
                                        Style="{StaticResource BadgeStyle}"
                                        Background="#FEF3C7"
                                        Visibility="Collapsed">
                                    <TextBlock Text="⚠️ Périssable" 
                                               Foreground="#92400E"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Packaging Information -->
                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="📦 Informations d'Emballage" 
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Pièces par Emballage" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="PiecesPerPackage" 
                                               Style="{StaticResource ValueStyle}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Type d'Emballage" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="PackageType" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Poids (Kg)" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="PackageWeight" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="6">
                                    <TextBlock Text="Dimensions" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="PackageDimensions" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Nombre d'Emballages" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TotalPackages" 
                                               Style="{StaticResource ValueStyle}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Dates & Lot Information -->
                    <Border Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock Text="📅 Dates et Lots" 
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Date" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="DateArticle" Style="{StaticResource ValueStyle}"/>

                                    <TextBlock Text="Numéro de Lot" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="NumeroLot" Style="{StaticResource ValueStyle}" FontFamily="Consolas"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Date de Livraison" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="DateLivraison" Style="{StaticResource ValueStyle}"/>

                                    <TextBlock Text="Bon de Livraison" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="BonLivraison" Style="{StaticResource ValueStyle}" FontFamily="Consolas"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Date d'Expiration" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="DateExpiration" Style="{StaticResource ValueStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Notes -->
                    <Border Style="{StaticResource InfoCardStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="📝 Notes" 
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <TextBlock x:Name="Notes" 
                                       Style="{StaticResource ValueStyle}"
                                       Margin="0"
                                       FontStyle="Italic"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceWhite}"
                    CornerRadius="0,0,24,24"
                    BorderBrush="{StaticResource BorderLight}"
                    BorderThickness="0,1,0,0"
                    Padding="40,24">
                <Button Content="✅ Fermer" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="200"
                        HorizontalAlignment="Center"
                        Click="CloseButton_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
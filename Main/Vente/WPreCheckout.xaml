<Window x:Class="GestionComerce.Main.Vente.WPreCheckout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:res="clr-namespace:GestionComerce.Resources"
        mc:Ignorable="d"
        Title="{x:Static res:Resources.SaleValidation}"
        Height="800" Width="1400"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="#F0F2F5">

    <Window.Resources>

        <!-- ══ Color Palette ══════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="PageBg"          Color="#F0F2F5"/>
        <SolidColorBrush x:Key="White"            Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderLight"      Color="#E8ECF0"/>
        <SolidColorBrush x:Key="BorderMid"        Color="#D0D7DE"/>
        <SolidColorBrush x:Key="PrimaryBlue"      Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryBlueDark"  Color="#1D4ED8"/>
        <SolidColorBrush x:Key="PrimaryBlueLight" Color="#3B82F6"/>
        <SolidColorBrush x:Key="BlueBadgeBg"      Color="#EFF6FF"/>
        <SolidColorBrush x:Key="SuccessGreen"     Color="#059669"/>
        <SolidColorBrush x:Key="GreenBadgeBg"     Color="#ECFDF5"/>
        <SolidColorBrush x:Key="DangerRed"        Color="#DC2626"/>
        <SolidColorBrush x:Key="WarningOrange"    Color="#D97706"/>
        <SolidColorBrush x:Key="WarningBg"        Color="#FFFBEB"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondary"    Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#94A3B8"/>
        <SolidColorBrush x:Key="TableHeaderBg"    Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SidebarBg"        Color="#FFFFFF"/>

        <!-- Drop-shadow effect for cards -->
        <DropShadowEffect x:Key="CardShadow"
                          Color="#1E293B"
                          Direction="270"
                          ShadowDepth="2"
                          BlurRadius="12"
                          Opacity="0.06"/>

        <DropShadowEffect x:Key="HeaderShadow"
                          Color="#1E293B"
                          Direction="270"
                          ShadowDepth="1"
                          BlurRadius="8"
                          Opacity="0.08"/>

        <!-- ══ Primary Button ════════════════════════════════════════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="24,12"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Effect"          Value="{StaticResource CardShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="#2563EB" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Success / Confirm Button ══════════════════════════════════════ -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background"      Value="#059669"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="28,13"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Effect"          Value="{StaticResource CardShadow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#047857"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Secondary / Outline Button ════════════════════════════════════ -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="BorderBrush"     Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="20,12"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Icon Button (small, square) ══════════════════════════════════ -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Styled TextBox ════════════════════════════════════════════════ -->
        <Style x:Key="StyledTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Foreground"               Value="#0F172A"/>
            <Setter Property="BorderBrush"              Value="#D0D7DE"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="Padding"                  Value="11,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"     Value="#2563EB"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="1.5"/>
                                <Setter TargetName="bd" Property="Background"      Value="#FAFCFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Styled ComboBox ═══════════════════════════════════════════════ -->
        <Style x:Key="StyledComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#0F172A"/>
            <Setter Property="BorderBrush"     Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="11,10"/>
            <Setter Property="Height"          Value="42"/>
        </Style>

        <!-- ══ Card ══════════════════════════════════════════════════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#E8ECF0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Effect"          Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- ══ Sidebar Card (no extra shadow, clean) ═════════════════════════ -->
        <Style x:Key="SideCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- ══ Field Label ═══════════════════════════════════════════════════ -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin"     Value="0,0,0,5"/>
        </Style>

        <!-- ══ Card Section Title ═════════════════════════════════════════════ -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>

        <!-- ══ Badge (pill) ══════════════════════════════════════════════════ -->
        <Style x:Key="BadgeBlue" TargetType="Border">
            <Setter Property="CornerRadius"  Value="20"/>
            <Setter Property="Padding"       Value="10,3"/>
            <Setter Property="Background"    Value="#EFF6FF"/>
        </Style>

        <Style x:Key="BadgeGreen" TargetType="Border">
            <Setter Property="CornerRadius"  Value="20"/>
            <Setter Property="Padding"       Value="10,3"/>
            <Setter Property="Background"    Value="#ECFDF5"/>
        </Style>

        <!-- ══ Table Column Header ════════════════════════════════════════════ -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin"     Value="0"/>
        </Style>

        <!-- ══ Summary Row Label ══════════════════════════════════════════════ -->
        <Style x:Key="SummaryLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SummaryValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!--  ROOT — three rows: header / body / footer                            -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <Grid Background="{StaticResource PageBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderLight}"
                BorderThickness="0,0,0,1"
                Effect="{StaticResource HeaderShadow}">
            <Grid Margin="32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Accent bar + title + payment badges -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Gradient accent bar -->
                    <Border Width="4" Height="34" CornerRadius="2" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#1D4ED8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Static res:Resources.SaleValidation}"
                                   FontSize="18" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Foreground="{StaticResource TextPrimary}"
                                   LineHeight="22"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Style="{StaticResource BadgeBlue}" Margin="0,0,8,0">
                                <TextBlock x:Name="PaymentMethodText"
                                           Text="{x:Static res:Resources.CashPayment}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryBlue}"/>
                            </Border>
                            <Border Style="{StaticResource BadgeGreen}">
                                <TextBlock x:Name="PaymentTypeText"
                                           Text="{x:Static res:Resources.CashSale}"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource SuccessGreen}"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Add article button -->
                <Button Grid.Column="2"
                        Style="{StaticResource SecondaryButton}"
                        Click="AddArticleButton_Click"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="+ " FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBlue}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Static res:Resources.AddArticle}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ══ BODY ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="24,20,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="650"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1*" MinWidth="370" MaxWidth="430"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Cart Panel ─────────────────────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Table header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource TableHeaderBg}"
                            CornerRadius="12,12,0,0"
                            BorderBrush="{StaticResource BorderLight}"
                            BorderThickness="0,0,0,1"
                            Padding="24,14,24,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cart title -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="28" Height="28" CornerRadius="7"
                                        Background="{StaticResource BlueBadgeBg}"
                                        Margin="0,0,10,0">
                                    <TextBlock Text="🛒" FontSize="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{x:Static res:Resources.CartItems}"
                                           Style="{StaticResource CardTitle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="PRIX UNIT."
                                       Style="{StaticResource ColHeader}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="QUANTITÉ"
                                       Style="{StaticResource ColHeader}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="REMISE %"
                                       Style="{StaticResource ColHeader}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="TOTAL"
                                       Style="{StaticResource ColHeader}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                        </Grid>
                    </Border>

                    <!-- Scrollable article rows -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20,16">
                        <StackPanel x:Name="ArticlesContainer"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ── RIGHT: Sidebar ──────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- ── Client Card ── -->
                    <Border Style="{StaticResource SideCard}" Padding="20">
                        <StackPanel>
                            <!-- Section header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="{StaticResource BlueBadgeBg}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="👤" FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{x:Static res:Resources.Client}"
                                           Style="{StaticResource CardTitle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Warning banner -->
                            <Border x:Name="ClientRequiredBanner"
                                    Background="{StaticResource WarningBg}"
                                    BorderBrush="#FCD34D"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,12"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠  " FontSize="12" Foreground="#92400E"/>
                                    <TextBlock x:Name="ClientSelectionRequired"
                                               Text="{x:Static res:Resources.ClientSelectionRequired}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="#92400E"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Search field -->
                            <TextBlock Text="{x:Static res:Resources.SearchSelect}"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="ClientSearchBox"
                                     Height="42"
                                     Style="{StaticResource StyledTextBox}"
                                     Margin="0,0,0,10"
                                     TextChanged="ClientSearchBox_TextChanged"/>

                            <!-- Client dropdown -->
                            <TextBlock Text="CLIENT" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="ClientComboBox"
                                      Style="{StaticResource StyledComboBox}"
                                      Margin="0,0,0,12"
                                      SelectionChanged="ClientComboBox_SelectionChanged"/>

                            <!-- New client button -->
                            <Button Content="{x:Static res:Resources.NewClient}"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="12,9" FontSize="12"
                                    Click="NewClientButton_Click"
                                    HorizontalAlignment="Stretch"/>

                            <!-- Selected client info panel -->
                            <Border x:Name="ClientInfoPanel"
                                    Background="#F0FDF4"
                                    BorderBrush="#86EFAC"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,12,0,0"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="{x:Static res:Resources.ClientInfo}"
                                               Style="{StaticResource FieldLabel}"/>
                                    <TextBlock x:Name="ClientNameText"
                                               FontSize="14" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               Foreground="{StaticResource TextPrimary}"
                                               Margin="0,0,0,2"/>
                                    <TextBlock x:Name="ClientPhoneText"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{x:Static res:Resources.ClientDiscount}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,0,4,0"/>
                                        <TextBlock x:Name="ClientDiscountValue"
                                                   Text="0%"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessGreen}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── Credit Section (PaymentType == 1) ── -->
                    <Border x:Name="CreditSection"
                            Background="White"
                            BorderBrush="#FCD34D"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,0,12"
                            Effect="{StaticResource CardShadow}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="{StaticResource WarningBg}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="💰" FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{x:Static res:Resources.CreditAmount}"
                                           FontSize="14" FontWeight="Bold"
                                           FontFamily="Segoe UI"
                                           Foreground="#92400E"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="MONTANT CRÉDIT (DH)"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="CreditTextBox"
                                     Height="42"
                                     Style="{StaticResource StyledTextBox}"
                                     Margin="0,0,0,6"
                                     TextChanged="CreditTextBox_TextChanged"/>
                            <TextBlock Text="{x:Static res:Resources.CreditAmountNote}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Additional Discount Card ── -->
                    <Border Style="{StaticResource SideCard}" Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="#FFF7ED"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="🏷️" FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{x:Static res:Resources.AdditionalDiscount}"
                                           Style="{StaticResource CardTitle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="VALEUR" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="AdditionalDiscountTextBox"
                                         Grid.Column="0" Height="42"
                                         Style="{StaticResource StyledTextBox}"
                                         Text="0"
                                         TextChanged="AdditionalDiscountTextBox_TextChanged"/>
                                <ComboBox x:Name="DiscountTypeComboBox"
                                          Grid.Column="2" Height="42"
                                          Style="{StaticResource StyledComboBox}"
                                          SelectedIndex="0"
                                          SelectionChanged="DiscountTypeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="%"/>
                                    <ComboBoxItem Content="DH"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Summary Card ── -->
                    <Border Style="{StaticResource SideCard}" Padding="20">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="{StaticResource BlueBadgeBg}"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="📊" FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{x:Static res:Resources.Summary}"
                                           Style="{StaticResource CardTitle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Sous-total -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static res:Resources.SubtotalLabel}"
                                           Style="{StaticResource SummaryLabel}"/>
                                <TextBlock x:Name="SubtotalText"
                                           Grid.Column="1"
                                           Text="0.00 DH"
                                           Style="{StaticResource SummaryValue}"/>
                            </Grid>

                            <!-- Total discount -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static res:Resources.TotalDiscount}"
                                           Style="{StaticResource SummaryLabel}"/>
                                <TextBlock x:Name="TotalDiscountText"
                                           Grid.Column="1"
                                           Text="0.00 DH"
                                           FontSize="13" FontWeight="SemiBold"
                                           FontFamily="Segoe UI"
                                           Foreground="{StaticResource DangerRed}"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Divider -->
                            <Border Height="1"
                                    Background="{StaticResource BorderLight}"
                                    Margin="0,0,0,16"/>

                            <!-- Total TTC highlighted box with gradient -->
                            <Border CornerRadius="10" Padding="16,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EFF6FF" Offset="0"/>
                                        <GradientStop Color="#DBEAFE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#BFDBFE" Offset="0"/>
                                        <GradientStop Color="#93C5FD" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="TOTAL TTC"
                                                   FontSize="10" FontWeight="Bold"
                                                   FontFamily="Segoe UI"
                                                   Foreground="{StaticResource PrimaryBlue}"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="{x:Static res:Resources.TotalTTC}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI"
                                                   Foreground="#1E40AF"/>
                                    </StackPanel>
                                    <TextBlock x:Name="TotalTTCText"
                                               Grid.Column="1"
                                               Text="0.00 DH"
                                               FontSize="28" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               Foreground="{StaticResource PrimaryBlue}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══ FOOTER ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource BorderLight}"
                BorderThickness="0,1,0,0"
                Padding="32,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: info hint -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="12"
                            Background="{StaticResource BlueBadgeBg}"
                            Margin="0,0,8,0">
                        <TextBlock Text="💡" FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{x:Static res:Resources.CheckInfo}"
                               FontSize="12"
                               Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: action buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{x:Static res:Resources.Cancel}"
                            Style="{StaticResource SecondaryButton}"
                            Width="130"
                            Click="CancelButton_Click"
                            Margin="0,0,10,0"/>
                    <Button x:Name="ContinueButton"
                            Style="{StaticResource SuccessButton}"
                            Width="200"
                            Click="ContinueButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9"
                                    Background="#FFFFFF26"
                                    Margin="0,0,8,0">
                                <TextBlock Text="✓" FontSize="11" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{x:Static res:Resources.ConfirmSale}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

<Window x:Class="GestionComerce.Main.Facturation.WSavedInvoiceLinker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lier à une Facture Enregistrée"
        Height="720" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- ── Button styles (same palette as WConfirmTransaction) ── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"   Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessBtn" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#059669"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"   Value="False">
                                <Setter Property="Background" Value="#6EE7B7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GrayBtn" TargetType="Button">
            <Setter Property="Background" Value="#6B7280"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4B5563"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#374151"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OrangeBtn" TargetType="Button">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D97706"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#B45309"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DataGrid cell / header polish ── -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E40AF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ══════════════════ SHELL ══════════════════ -->
    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- header bar -->
                <RowDefinition Height="*"/>
                <!-- body -->
                <RowDefinition Height="Auto"/>
                <!-- footer buttons -->
            </Grid.RowDefinitions>

            <!-- ── HEADER ── -->
            <Border Grid.Row="0" Background="#3B82F6" CornerRadius="12,12,0,0" Padding="22,14">
                <TextBlock Text="📄  Lier à une Facture Enregistrée"
                           FontSize="16" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- ── BODY ── -->
            <Grid Grid.Row="1" Margin="22,18,22,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- mode radio -->
                    <RowDefinition Height="Auto"/>
                    <!-- divider -->
                    <RowDefinition Height="Auto"/>
                    <!-- panel: create OR select -->
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <!-- articles from operation label -->
                    <RowDefinition Height="180"/>
                    <!-- articles from operation grid -->
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <!-- articles in saved-invoice label -->
                    <RowDefinition Height="*"/>
                    <!-- articles in saved-invoice grid -->
                </Grid.RowDefinitions>

                <!-- ── MODE SELECTOR ── -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="rbCreate"
                                 Content="  Créer une nouvelle facture enregistrée"
                                 FontSize="13" FontWeight="SemiBold" Foreground="#1F2937"
                                 IsChecked="True"
                                 Checked="ModeRadio_Changed"/>
                    <RadioButton x:Name="rbExisting"
                                 Content="  Ajouter à une facture existante"
                                 FontSize="13" FontWeight="SemiBold" Foreground="#1F2937"
                                 Margin="30,0,0,0"
                                 Checked="ModeRadio_Changed"/>
                </StackPanel>

                <Border Grid.Row="1" Height="1" Background="#E5E7EB" Margin="0,0,0,14"/>

                <!-- ── PANELS (toggled by radio) ── -->
                <Grid Grid.Row="2">

                    <!-- CREATE PANEL -->
                    <Border x:Name="panelCreate" Visibility="Visible"
                            Background="#F8FAFC" CornerRadius="8" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: labels -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Référence" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Description" FontSize="12" Foreground="#6B7280"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Montant total (DH)" FontSize="12" Foreground="#6B7280"/>

                            <!-- Row 2: inputs -->
                            <TextBox x:Name="txtNewRef" Grid.Row="2" Grid.Column="0"
                                     Height="34" Padding="10,6" FontSize="13"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Background="White"/>
                            <TextBox x:Name="txtNewDesc" Grid.Row="2" Grid.Column="2"
                                     Height="34" Padding="10,6" FontSize="13"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Background="White"/>
                            <TextBox x:Name="txtNewAmount" Grid.Row="2" Grid.Column="4"
                                     Height="34" Padding="10,6" FontSize="13"
                                     BorderBrush="#D1D5DB" BorderThickness="1" Background="White"
                                     PreviewTextInput="DecimalOnly_PreviewTextInput"/>

                            <!-- Image browse -->
                            <StackPanel Grid.Row="2" Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6"
                                        Padding="8,6" Background="White" Margin="0,0,8,0" MinWidth="130">
                                    <TextBlock x:Name="txtImageName" Text="Aucune image"
                                               FontSize="12" Foreground="#6B7280"
                                               TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                                </Border>
                                <Button Content="📂 Image" Style="{StaticResource OrangeBtn}"
                                        Padding="12,6" FontSize="12"
                                        Click="BrowseImage_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- EXISTING PANEL -->
                    <Border x:Name="panelExisting" Visibility="Collapsed"
                            Background="#F8FAFC" CornerRadius="8" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="cmbExistingInvoices"
                                      Height="36" FontSize="13"
                                      BorderBrush="#D1D5DB" BorderThickness="1"
                                      DisplayMemberPath="DisplayLabel"
                                      SelectedValuePath="SavedInvoiceID"
                                      SelectionChanged="cmbExistingInvoices_SelectionChanged"/>

                            <Button Grid.Column="2" Content="🔄 Actualiser"
                                    Style="{StaticResource PrimaryBtn}"
                                    Padding="14,8" FontSize="12"
                                    Click="RefreshExisting_Click"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── OPERATION ARTICLES (articles being purchased) ── -->
                <TextBlock Grid.Row="4"
                           Text="Articles de l'opération (à lier)"
                           FontSize="13" FontWeight="SemiBold" Foreground="#374151"
                           Margin="0,0,0,6"/>

                <DataGrid Grid.Row="5" x:Name="dgOperationArticles"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="White"
                          BorderBrush="#E5E7EB" BorderThickness="1"
                          RowHeight="36" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Article" Binding="{Binding ArticleName}" Width="*"/>
                        <DataGridTextColumn Header="Prix unitaire" Binding="{Binding PrixUnitaire, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Quantité" Binding="{Binding Quantite}" Width="80"/>
                        <DataGridTextColumn Header="TVA (%)" Binding="{Binding Tva}" Width="80"/>
                        <DataGridTextColumn Header="Total HT" Binding="{Binding TotalHT, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Total TTC" Binding="{Binding TotalTTC, StringFormat='{}{0:N2}'}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ── EXISTING SAVED-INVOICE ARTICLES (shown when rbExisting is selected) ── -->
                <TextBlock Grid.Row="7" x:Name="lblExistingArticles"
                           Text="Articles déjà dans la facture sélectionnée"
                           FontSize="13" FontWeight="SemiBold" Foreground="#374151"
                           Margin="0,0,0,6"
                           Visibility="Collapsed"/>

                <DataGrid Grid.Row="8" x:Name="dgExistingArticles"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="White"
                          BorderBrush="#E5E7EB" BorderThickness="1"
                          RowHeight="34" FontSize="12"
                          Visibility="Collapsed">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Article" Binding="{Binding ArticleName}" Width="*"/>
                        <DataGridTextColumn Header="Prix unitaire" Binding="{Binding PrixUnitaire, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Quantité" Binding="{Binding Quantite}" Width="80"/>
                        <DataGridTextColumn Header="TVA (%)" Binding="{Binding Tva}" Width="80"/>
                        <DataGridTextColumn Header="Total HT" Binding="{Binding TotalHT, StringFormat='{}{0:N2}'}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ── FOOTER ── -->
            <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="22,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- status label -->
                    <TextBlock x:Name="lblStatus" Grid.Column="0"
                               FontSize="12" Foreground="#6B7280"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>

                    <!-- action buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="btnCancel" Content="Annuler"
                                Style="{StaticResource GrayBtn}"
                                Margin="0,0,12,0"
                                Click="Cancel_Click"/>
                        <Button x:Name="btnConfirm" Content="✔  Confirmer et enregistrer"
                                Style="{StaticResource SuccessBtn}"
                                Click="Confirm_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

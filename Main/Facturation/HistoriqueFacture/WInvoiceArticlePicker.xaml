<Window x:Class="GestionComerce.Main.Facturation.HistoriqueFacture.WInvoiceArticlePicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajouter des Articles"
        Width="860"
        Height="720"
        MinWidth="720"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>

        <!-- Modern TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#93C5FD"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="22,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Article ListBox Item Style -->
        <Style x:Key="ArticleListItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="0,0,0,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Outer shadow -->
    <Border Margin="15" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="24" ShadowDepth="0"/>
        </Border.Effect>

        <Border Background="#F9FAFB" CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1: Search -->
                    <RowDefinition Height="*"/>
                    <!-- 2: Catalogue -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3: Section bar -->
                    <RowDefinition Height="180"/>
                    <!-- 4: Staging grid -->
                    <RowDefinition Height="Auto"/>
                    <!-- 5: Footer -->
                </Grid.RowDefinitions>

                <!-- ── HEADER ─────────────────────────────────────────────── -->
                <Border Grid.Row="0" Background="White" CornerRadius="14,14,0,0" Padding="28,20,20,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ajouter des Articles à la Facture"
                                       FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                            <TextBlock Text="Cliquez sur un article pour le sélectionner · ajustez la quantité dans le tableau"
                                       FontSize="13" Foreground="#6B7280" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource CloseButton}"
                                Content="✕" Click="btnClose_Click"/>
                    </Grid>
                </Border>

                <!-- ── SEARCH ─────────────────────────────────────────────── -->
                <Border Grid.Row="1" Background="White" Padding="28,12,28,12">
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="16"
                                       VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <TextBox Grid.Column="1" x:Name="txtSearch"
                                     FontSize="14" Height="40" Padding="0,0,12,0"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0" Background="Transparent"
                                     TextChanged="txtSearch_TextChanged"/>
                        </Grid>
                    </Border>
                </Border>

                <!-- ── CATALOGUE (multi-select) ───────────────────────────── -->
                <Border Grid.Row="2" Background="White" Padding="28,0,28,8">
                    <ListBox x:Name="lstArticles"
                             BorderThickness="1" BorderBrush="#E5E7EB"
                             Background="White"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionMode="Multiple"
                             ItemContainerStyle="{StaticResource ArticleListItem}"
                             SelectionChanged="lstArticles_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,11,14,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Blue checkbox indicator -->
                                        <Border Grid.Column="0"
                                                x:Name="chkBox"
                                                Width="20" Height="20"
                                                CornerRadius="4"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center"
                                                Background="#E5E7EB"
                                                BorderBrush="#D1D5DB"
                                                BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#E5E7EB"/>
                                                    <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected,
                                                            RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                            Value="True">
                                                            <Setter Property="Background" Value="#3B82F6"/>
                                                            <Setter Property="BorderBrush" Value="#2563EB"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="✓" FontSize="11" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected,
                                                                RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Name + Code -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ArticleName}"
                                                       FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                                            <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,2,0,0">
                                                <Run Text="Code: "/><Run Text="{Binding Code}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Price + Stock -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PrixVente, StringFormat={}{0:N2} DH}"
                                                       FontSize="15" FontWeight="Bold"
                                                       Foreground="#3B82F6" HorizontalAlignment="Right"/>
                                            <TextBlock FontSize="12" Foreground="#6B7280"
                                                       HorizontalAlignment="Right" Margin="0,2,0,0">
                                                <Run Text="Stock: "/><Run Text="{Binding Quantite}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- ── SECTION BAR ─────────────────────────────────────────── -->
                <Border Grid.Row="3" Background="#F3F4F6"
                        BorderBrush="#E5E7EB" BorderThickness="0,1,0,1"
                        Padding="28,8,28,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Articles sélectionnés"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <Border Background="#3B82F6" CornerRadius="10"
                                    Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="lblCount" Text="0"
                                           FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="Modifiez Qté, Prix et TVA directement dans le tableau"
                                   FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ── STAGING DATAGRID ────────────────────────────────────── -->
                <Border Grid.Row="4" Background="White" Padding="28,8,28,8">
                    <DataGrid x:Name="dgSelectedArticles"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeight="44"
                              FontSize="13"
                              BorderBrush="#E5E7EB"
                              BorderThickness="1"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="#F9FAFB"
                              HorizontalGridLinesBrush="#F3F4F6"
                              SelectionMode="Single"
                              CellEditEnding="dgSelectedArticles_CellEditEnding">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Article"
                                               Binding="{Binding ArticleName}"
                                               Width="2*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#111827"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Qté"
                                               Binding="{Binding Quantite, UpdateSourceTrigger=PropertyChanged}"
                                               Width="*"/>
                            <DataGridTextColumn Header="Prix Unit."
                                               Binding="{Binding PrixUnitaire, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}"
                                               Width="*"/>
                            <DataGridTextColumn Header="TVA (%)"
                                               Binding="{Binding TVA, StringFormat={}{0:N2}, UpdateSourceTrigger=PropertyChanged}"
                                               Width="*"/>
                            <DataGridTextColumn Header="Total HT"
                                               Binding="{Binding TotalHT, StringFormat={}{0:N2} DH}"
                                               Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#3B82F6"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="12,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <!-- Remove row -->
                            <DataGridTemplateColumn Header="" Width="52">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕"
                                                Width="28" Height="28"
                                                FontSize="12" FontWeight="Bold"
                                                Background="#FEE2E2" Foreground="#DC2626"
                                                BorderThickness="0" Cursor="Hand"
                                                Tag="{Binding}"
                                                Click="btnRemoveRow_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#FCA5A5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- ── FOOTER ─────────────────────────────────────────────── -->
                <Border Grid.Row="5"
                        Background="White"
                        CornerRadius="0,0,14,14"
                        Padding="28,16,28,20"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Total HT (tous articles)"
                                       FontSize="12" Foreground="#6B7280"/>
                            <TextBlock x:Name="lblTotalHT"
                                       Text="0,00 DH"
                                       FontSize="24" FontWeight="Bold" Foreground="#3B82F6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Annuler"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,12,0"
                                    Click="btnCancel_Click"/>
                            <Button x:Name="btnAdd"
                                    Content="+ Ajouter à la facture"
                                    Style="{StaticResource PrimaryButton}"
                                    IsEnabled="False"
                                    Click="btnAdd_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>

</Window>

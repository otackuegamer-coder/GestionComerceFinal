<Window x:Class="Superete.Main.Comptabilite.HistoriquePaiementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historique des Paiements"
        Height="600" Width="1050"
        WindowStartupLocation="CenterOwner"
        Background="#FAFBFC"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#667EEA">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0">
                <TextBlock Text="📋" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock x:Name="txtWindowTitle" Text="" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="txtSubtitle" Text="" FontSize="12" Foreground="#C3DAFE"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Status filter -->
                <ComboBox x:Name="cmbFiltreStatut" Width="160" Height="34" Margin="0,0,12,0"
                          FontSize="13" SelectionChanged="FiltreStatut_Changed"/>
                <!-- Year filter -->
                <ComboBox x:Name="cmbFiltreAnnee" Width="100" Height="34" Margin="0,0,12,0"
                          FontSize="13" SelectionChanged="FiltreAnnee_Changed"/>
                <!-- Spacer -->
                <TextBlock VerticalAlignment="Center" Margin="0,0,16,0" Foreground="#718096"
                           x:Name="txtTotalRecords" FontSize="13"/>
                <Border Width="1" Background="#E2E8F0" Margin="0,8"/>
                <!-- Export -->
                <Button x:Name="btnExporter" Height="34" Padding="16,0" Margin="16,0,0,0"
                        Cursor="Hand" Click="BtnExporter_Click"
                        Background="#48BB78" Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📊" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="btnExportLabel" Text="Exporter Excel"
                                               FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#38A169"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgHistorique"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionMode="Single"
                  GridLinesVisibility="None" BorderThickness="0"
                  Background="White" RowHeight="48" FontSize="13"
                  HeadersVisibility="Column" RowDetailsVisibilityMode="Collapsed">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F7FAFC"/>
                    <Setter Property="Foreground" Value="#4A5568"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="12,12"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="Height" Value="44"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#F7FAFC"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FAFBFC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="12,0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#2D3748"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="colPeriode"  Header="Période"        Binding="{Binding PeriodeDisplay}" Width="90"/>
                <DataGridTextColumn x:Name="colDatePmt"  Header="Date Paiement"  Binding="{Binding DatePaiement, StringFormat={}{0:dd/MM/yyyy}}" Width="110"/>
                <DataGridTextColumn x:Name="colBase"     Header="Salaire Base"   Binding="{Binding SalaireBase, StringFormat={}{0:N2} DH}" Width="110"/>
                <DataGridTextColumn x:Name="colHS"       Header="H. Supp."       Binding="{Binding MontantHeuresSupp, StringFormat={}{0:N2} DH}" Width="90"/>
                <DataGridTextColumn x:Name="colPrimes"   Header="Primes"
                                    Binding="{Binding TotalPrimesDisplay, StringFormat={}{0:N2} DH}" Width="90"/>
                <DataGridTextColumn x:Name="colBrut"     Header="Salaire Brut"   Binding="{Binding SalaireBrut, StringFormat={}{0:N2} DH}" Width="110"/>
                <DataGridTextColumn x:Name="colRetenues" Header="Retenues"       Binding="{Binding TotalRetenues, StringFormat={}{0:N2} DH}" Width="100"/>
                <DataGridTextColumn x:Name="colNet"      Header="Salaire Net"    Binding="{Binding SalaireNet, StringFormat={}{0:N2} DH}" Width="110"/>
                <DataGridTemplateColumn x:Name="colStatut" Header="Statut" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Padding="8,4" CornerRadius="6" HorizontalAlignment="Left" Margin="0,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Statut}" Value="Payé">
                                                <Setter Property="Background" Value="#D1FAE5"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Statut}" Value="Validé">
                                                <Setter Property="Background" Value="#DBEAFE"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Statut}" Value="En Attente">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Statut}" FontSize="12" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Statut}" Value="Payé">
                                                    <Setter Property="Foreground" Value="#047857"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Statut}" Value="Validé">
                                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Statut}" Value="En Attente">
                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer totals -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="20,14">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="txtTotalAnnuel" FontSize="13" Foreground="#4A5568" Margin="0,0,24,0"/>
                    <TextBlock x:Name="txtTotalNet"    FontSize="14" FontWeight="Bold" Foreground="#2D3748"/>
                </StackPanel>
                <Button x:Name="btnFermer" HorizontalAlignment="Right"
                        Height="36" Padding="24,0" Click="BtnFermer_Click"
                        Cursor="Hand" Background="White" BorderBrush="#CBD5E0" BorderThickness="1">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#EDF2F7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="btnFermerLabel" Text="Fermer" FontSize="13" Foreground="#4A5568"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>